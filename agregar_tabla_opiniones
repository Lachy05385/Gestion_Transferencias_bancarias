if __name__ == "__main__":
    import sys
    
    if len(sys.argv) > 1 and sys.argv[1] == "--help":
        mostrar_ayuda()
        sys.exit(0)
    
    print("🚀 Iniciando migración de base de datos...")
    print("")
    
    # Verificar tablas actuales
    verificar_tablas()
    
    print("")
    
    # Agregar tabla opiniones
    if agregar_tabla_opiniones():
        print("")
        # Verificar/Agregar columna rol
        agregar_columna_rol_si_no_existe()
        
        print("")
