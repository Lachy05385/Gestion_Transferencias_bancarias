"""
Script para agregar la tabla 'opiniones' a la base de datos existente
No elimina datos existentes, solo agrega la nueva tabla
"""

import sqlite3
import os
from datetime import datetime

def agregar_tabla_opiniones():
    """Agrega la tabla opiniones a la base de datos sin afectar otras tablas"""
    
    # Ruta de la base de datos (ajusta si es necesario)
    db_path = "banco.db"
    
    if not os.path.exists(db_path):
        print(f"❌ Base de datos no encontrada en: {db_path}")
        print("   Verifica que la ruta sea correcta")
        return False
    
    print("="*60)
    print("📦 Agregando tabla 'opiniones' a la base de datos")
    print("="*60)
    
    try:
        # Conectar a la base de datos
        conn = sqlite3.connect(db_path)
        cursor = conn.cursor()
        
        # Verificar si la tabla ya existe
        cursor.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='opiniones'")
        if cursor.fetchone():
            print("⚠️ La tabla 'opiniones' ya existe")
            respuesta = input("¿Deseas recrearla? (perderás los datos de opiniones existentes) (s/n): ")
            if respuesta.lower() != 's':
                print("❌ Operación cancelada")
                conn.close()
                return False
            # Eliminar tabla existente
            cursor.execute("DROP TABLE IF EXISTS opiniones")
            print("🗑️ Tabla existente eliminada")
        
        # Crear la tabla opiniones
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS opiniones (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                usuario_id INTEGER NOT NULL,
                usuario_nombre VARCHAR(200) NOT NULL,
                titulo VARCHAR(100) NOT NULL,
                mensaje TEXT NOT NULL,
                puntuacion INTEGER DEFAULT 5,
                fecha TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                FOREIGN KEY (usuario_id) REFERENCES usuarios(id) ON DELETE CASCADE
            )
        """)
        print("✅ Tabla 'opiniones' creada correctamente")
        
        # Crear índices para mejorar búsquedas
        cursor.execute("CREATE INDEX IF NOT EXISTS idx_opiniones_usuario_id ON opiniones(usuario_id)")
        cursor.execute("CREATE INDEX IF NOT EXISTS idx_opiniones_fecha ON opiniones(fecha)")
        print("✅ Índices creados correctamente")
        
        # Verificar la estructura
        cursor.execute("PRAGMA table_info(opiniones)")
        columnas = cursor.fetchall()
        print("\n📋 Estructura de la tabla 'opiniones':")
        for col in columnas:
            print(f"   - {col[1]}: {col[2]} (nullable: {not col[3]})")
        
        # Contar registros insertados
        cursor.execute("SELECT COUNT(*) FROM opiniones")
        count = cursor.fetchone()[0]
        print(f"\n📊 Registros en la tabla: {count}")
        
        conn.commit()
        conn.close()
        
        print("\n" + "="*60)
        print("✅ Tabla 'opiniones' agregada exitosamente")
        print("="*60)
        return True
        
    except Exception as e:
        print(f"❌ Error al crear la tabla: {str(e)}")
        return False

def agregar_columna_rol_si_no_existe():
    """Verifica y agrega la columna 'rol' a la tabla usuarios si no existe"""
    
    db_path = "bancaria.db"
    
    if not os.path.exists(db_path):
        return False
    
    try:
        conn = sqlite3.connect(db_path)
        cursor = conn.cursor()
        
        # Verificar si la columna rol existe
        cursor.execute("PRAGMA table_info(usuarios)")
        columnas = [col[1] for col in cursor.fetchall()]
        
        if 'rol' not in columnas:
            print("\n⚠️ La columna 'rol' no existe en la tabla usuarios")
            respuesta = input("¿Deseas agregarla? (s/n): ")
            if respuesta.lower() == 's':
                cursor.execute("ALTER TABLE usuarios ADD COLUMN rol VARCHAR(20) DEFAULT 'usuario'")
                conn.commit()
                print("✅ Columna 'rol' agregada correctamente")
                
                # Actualizar admin si existe
                cursor.execute("UPDATE usuarios SET rol = 'admin' WHERE email LIKE '%admin%' OR email LIKE '%lazaro%'")
                conn.commit()
                print("✅ Usuarios admin actualizados (si existían)")
        else:
            print("✅ Columna 'rol' ya existe")
        
        conn.close()
        return True
    except Exception as e:
        print(f"❌ Error al verificar columna rol: {str(e)}")
        return False

def verificar_tablas():
    """Muestra todas las tablas existentes en la base de datos"""
    
    db_path = "bancaria.db"
    
    if not os.path.exists(db_path):
        print(f"❌ Base de datos no encontrada")
        return
    
    try:
        conn = sqlite3.connect(db_path)
        cursor = conn.cursor()
        
        cursor.execute("SELECT name FROM sqlite_master WHERE type='table' ORDER BY name")
        tablas = cursor.fetchall()
        
        print("\n📋 Tablas existentes en la base de datos:")
        for tabla in tablas:
            # Contar registros
            cursor.execute(f"SELECT COUNT(*) FROM {tabla[0]}")
            count = cursor.fetchone()[0]
            print(f"   - {tabla[0]}: {count} registros")
        
        conn.close()
    except Exception as e:
        print(f"❌ Error al verificar tablas: {str(e)}")

def mostrar_ayuda():
    """Muestra instrucciones de uso"""
    print("""
    📖 USO DEL SCRIPT:
    
    Este script agrega la tabla 'opiniones' a tu base de datos existente.
    
